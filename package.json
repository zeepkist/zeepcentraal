{
	"name": "@zeepkist/zeepcentraal",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev:server": "bun --watch packages/server/src/index.ts",
		"dev:jobs": "bun --watch packages/jobs/src/index.ts",
		"build:server": "bun --cwd=packages/server run build",
		"build:jobs": "bun --cwd=packages/jobs run build",
		"db:studio": "bun --cwd=packages/database run dev",
		"db:generate": "bun --cwd=packages/database run db:generate",
		"db:migrate": "bun --cwd=packages/database run db:migrate",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.6",
		"@types/bun": "~1.3.2",
		"@types/semver": "^7.7.0",
		"drizzle-kit": "^0.31.5",
		"typescript": "^5.9.2"
	},
	"dependencies": {
		"@opentelemetry/exporter-trace-otlp-grpc": "^0.219.0",
		"@opentelemetry/resources": "^2.8.0",
		"@opentelemetry/sdk-node": "^0.219.0",
		"@opentelemetry/semantic-conventions": "^1.41.1",
		"logixlysia": "^6.5.1"
	}
}
