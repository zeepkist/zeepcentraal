{
	"name": "@zeepkist/database",
	"version": "1.2.0",
	"private": true,
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"scripts": {
		"build": "bun build --compile --minify-whitespace --minify-syntax --outfile ../../dist/zeepcentraal-migrate src/migrate.ts",
		"release": "semantic-release",
		"dev": "drizzle-kit studio",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"exports": {
		".": {
			"import": "./src/index.ts"
		},
		"./services": {
			"import": "./src/services/index.ts"
		},
		"./services/workshop": {
			"import": "./src/services/workshop.ts"
		}
	},
	"dependencies": {
		"@opentelemetry/api": "~1.9.0",
		"drizzle-orm": "~0.45.0",
		"postgres": "~3.4.7",
		"semver": "~7.8.0",
		"ulid": "~3.0.2"
	},
	"devDependencies": {
		"@types/semver": "~7.7.0",
		"drizzle-kit": "~0.31.5"
	}
}
