FROM gcr.io/distroless/base

LABEL org.opencontainers.image.description="ZeepCentraal database migration runner for applying Drizzle schema migrations."

WORKDIR /app

COPY dist/zeepcentraal-migrate zeepcentraal-migrate
COPY packages/database/drizzle drizzle

ENV NODE_ENV=production

CMD ["./zeepcentraal-migrate"]
